{
  "name": "tasting-genie-2nd-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "lint:html": "htmlhint \"**/*.html\"",
    "lint:css": "stylelint \"**/*.css\"",
    "check": "npm run format:check && npm run lint:html && npm run lint:css"
  },
  "devDependencies": {
    "htmlhint": "^1.6.3",
    "prettier": "^3.8.3",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
